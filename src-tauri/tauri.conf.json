{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "以太测v1",
  "version": "1.0.0",
  "identifier": "com.stockpredict.app.v1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "以太测v1",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https: http: blob:; connect-src 'self' https: http: ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/stocks.json": "resources/stocks.json",
      "resources/message_weights_broad_etf.json": "resources/message_weights_broad_etf.json"
    }
  },
  "plugins": {
    "background-service": {
      "androidForegroundServiceTypes": ["dataSync", "remoteMessaging"],
      "androidValidateForegroundServiceType": true
    }
  }
}
